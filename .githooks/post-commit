#!/bin/bash
set -euo pipefail
# Auto-sync to GitHub after every commit (only when on main branch)

if [ -z "${GITHUB_TOKEN:-}" ]; then
  echo "[post-commit] GITHUB_TOKEN is not set — skipping GitHub sync"
  exit 0
fi

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")

if [ "$CURRENT_BRANCH" != "main" ]; then
  echo "[post-commit] Not on main (current: ${CURRENT_BRANCH}) — skipping GitHub sync"
  exit 0
fi

git config user.email "replit-agent@replit.com" 2>/dev/null || true
git config user.name "Replit Agent" 2>/dev/null || true

REMOTE_URL="https://${GITHUB_TOKEN}@github.com/shady-alaraby/SHADY-ODOO.git"

echo "[post-commit] Pushing main to GitHub..."

PUSH_OUTPUT=$(git push "$REMOTE_URL" "main:main" 2>&1) || PUSH_EXIT=$?
PUSH_EXIT=${PUSH_EXIT:-0}

SAFE_OUTPUT=$(printf '%s' "$PUSH_OUTPUT" | sed "s/${GITHUB_TOKEN}/***REDACTED***/g")
echo "$SAFE_OUTPUT"

if [ "$PUSH_EXIT" -eq 0 ]; then
  echo "[post-commit] Successfully pushed to GitHub."
else
  echo "[post-commit] Push to GitHub failed (exit ${PUSH_EXIT}). Check GITHUB_TOKEN and repo permissions."
  exit "$PUSH_EXIT"
fi
